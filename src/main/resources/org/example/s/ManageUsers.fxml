<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" stylesheets="@../../../css/manage-users.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ManageUsersController">
    <children>

        <!-- Top Section for Title -->
        <VBox alignment="CENTER" styleClass="title-box" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <Label alignment="CENTER" styleClass="title-label" text="Manage Users" />
        </VBox>

        <!-- Center Section for Table -->
        <TableView fx:id="usersTable" styleClass="users-table" AnchorPane.bottomAnchor="80.0" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="80.0">
            <columns>
                <TableColumn fx:id="userIdColumn" text="User ID" />
                <TableColumn fx:id="usernameColumn" text="User Name" />
                <TableColumn fx:id="emailColumn" text="Email" />
            </columns>
        </TableView>

        <!-- Bottom Section for Back Button -->
        <Button fx:id="backButton" styleClass="back-button" text="Go Back" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="350.0" />
    </children>
</AnchorPane>
