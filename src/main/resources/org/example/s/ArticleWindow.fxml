<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600" prefWidth="800" style="-fx-background-color: linear-gradient(to bottom, #ffffff, #f0f4f8);" stylesheets="@../../../css/article-read-style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ArticleReadController">
    <children>
        <VBox layoutX="20" layoutY="20" prefHeight="560" prefWidth="760" spacing="20">
            <!-- Article Title -->
            <Text fx:id="titleText" styleClass="title-text" wrappingWidth="720" />

            <!-- Metadata -->
            <Text fx:id="metadataText" styleClass="metadata-text" wrappingWidth="720" />

            <!-- Article Image -->
            <ImageView fx:id="articleImage" fitHeight="200" fitWidth="720" preserveRatio="true" />

            <!-- Content -->
            <TextArea fx:id="contentTextArea" editable="false" prefHeight="200" styleClass="content-area" wrapText="true" />

            <!-- Like and Dislike Buttons -->
            <HBox alignment="center" spacing="20">
                <Button fx:id="likeButton" onAction="#handleLikeButtonAction" styleClass="like-button" text="Like" />
                <Button fx:id="dislikeButton" onAction="#handleDislikeButtonAction" styleClass="dislike-button" text="Dislike" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>
