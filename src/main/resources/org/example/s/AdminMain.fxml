<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="565.0" prefWidth="600.0" stylesheets="@../../../css/register-style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminMainController">
    <children>

        <!-- Top Section for "Admin Authorities" Title -->
        <VBox alignment="CENTER" styleClass="title-box" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <Label alignment="CENTER" styleClass="title-label" text="Admin Authorities">
                <font>
                    <Font name="Arial Black" size="30.0" />
                </font>
            </Label>
        </VBox>

        <!-- Main Buttons Section -->
        <VBox alignment="CENTER" layoutY="76.8" maxWidth="600.0" prefHeight="354.0" prefWidth="600.0" spacing="10.0" styleClass="form-box" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="77.0">

            <!-- Manage Users Button -->
            <Button fx:id="manageUsers" styleClass="main-button" text="Manage Users">
                <font>
                    <Font size="16.0" />
                </font>
            </Button>

            <!-- Manage Articles Button -->
            <Button fx:id="manageArticles" styleClass="main-button" text="Turn on News API">
                <font>
                    <Font size="16.0" />
                </font>
            </Button>

            <!-- Go Back Button -->
            <Button fx:id="backButton" styleClass="back-button" text="Go Back (Log Out)">
                <font>
                    <Font size="16.0" />
                </font>
            </Button>
        </VBox>

    </children>
</AnchorPane>
