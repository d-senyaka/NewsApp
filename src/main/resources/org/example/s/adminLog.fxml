<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="743.0" prefWidth="668.0" stylesheets="@../../../css/login-style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.AdminLoginController">
    <children>
        <!-- Top Section for Title -->
        <VBox alignment="CENTER" prefHeight="100.0" styleClass="top-section" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label styleClass="title-label" text="Admin Login" textFill="white" />
            </children>
        </VBox>

        <!-- Center Section containing Admin Login Form -->
        <HBox alignment="CENTER" prefHeight="500.0" spacing="30.0" styleClass="center-section" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="120.0">
            <children>
                <VBox alignment="CENTER" spacing="15.0" styleClass="admin-login-section">
                    <children>
                        <Label styleClass="section-title" text="Administrator Login" />
                        <TextField fx:id="adminNameField" promptText="Admin Name" styleClass="input-field" />
                        <PasswordField fx:id="passwordField" promptText="Password" styleClass="input-field" />
                        <Button fx:id="confirmLoginButton" onAction="#handleLogin" styleClass="login-button" text="Confirm Login" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- Bottom Section for Back and Home Buttons -->
        <HBox alignment="CENTER" prefHeight="100.0" spacing="20.0" styleClass="bottom-section" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <Button fx:id="backButton"  text="Back" styleClass="bottom-button" />
                <Button fx:id="homeButton"  text="Home" styleClass="bottom-button" />
            </children>
        </HBox>
    </children>
</AnchorPane>
