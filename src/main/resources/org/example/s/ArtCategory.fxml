<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="619.0" prefWidth="680.0" styleClass="root-pane" stylesheets="@../../../css/category.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" >
    <children>
        <!-- VBox containing headline and dropdown menu -->
        <VBox spacing="20" styleClass="header-container" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <!-- Headline -->
            <Text styleClass="headline-text" text="HeadLines Plus" />

            <!-- HBox for dropdown and label -->
            <HBox spacing="20" styleClass="filter-container">
                <ComboBox fx:id="categoryDropdown" promptText="Filter by Category" styleClass="dropdown-menu" />
                <Label fx:id="selectedCategoryLabel" styleClass="category-label" text="Selected Category: None" />
                <Label fx:id="userLabel" styleClass="category-label" text="User: Guest" />
            </HBox>

            <!-- ScrollPane for articles -->
            <ScrollPane fx:id="articlesScrollPane" prefHeight="470.0" prefWidth="600.0">
                <VBox fx:id="articlesContainer" spacing="10" styleClass="articles-container" />
            </ScrollPane>

            <!-- HBox for buttons -->
            <HBox alignment="center" spacing="20" styleClass="button-container">
                <Button fx:id="recommendationButton" onAction="#handleRecommendationButtonClick" styleClass="nav-button" text="My Recommendations" />

                <Button fx:id="historyButton" styleClass="nav-button" text="My History" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>

