<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="619.0" prefWidth="680.0" styleClass="root-pane" stylesheets="@../../../css/article-style1.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.ArticlesController">
    <children>
        <!-- VBox containing headline and buttons -->
        <VBox spacing="20" styleClass="header-container" AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0" AnchorPane.topAnchor="20.0">
            <!-- Headline -->
            <Text styleClass="headline-text" text="HeadLines Plus" />
            <Text styleClass="subtext" text="Check out these samples of our news and articleAPIS! There's much more we provide beyond what’s showcased here." />

            <!-- ScrollPane for articleAPIS -->
            <ScrollPane fx:id="articlesScrollPane" prefHeight="441.0" prefWidth="600.0">
                <VBox fx:id="articlesContainer" spacing="10" styleClass="articleAPIS-container" />
            </ScrollPane>

            <!-- New subtext -->
            <Text styleClass="subtext" text="To use our full  services you need to Create an account or Log In first" />

            <!-- HBox for buttons -->
            <HBox alignment="center" spacing="20" styleClass="button-container">
                <Button fx:id="createAccountButton" onAction="#handleCreateAccount" styleClass="nav-button" text="Create Account" />
                <Button fx:id="loginButton" onAction="#handleLogIn" styleClass="nav-button" text="Log In" />
            </HBox>
        </VBox>
    </children>
</AnchorPane>
