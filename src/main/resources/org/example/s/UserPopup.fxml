<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="300.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.UserPopupController">
    <children>
        <VBox alignment="CENTER" spacing="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="20.0">
            <Label text="User Details" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Label fx:id="userIdLabel" text="User ID: " />
            <Label fx:id="usernameLabel" text="Username: " />
            <Label fx:id="emailLabel" text="Email: " />
        </VBox>
        <Button fx:id="deleteButton" text="Delete User" style="-fx-font-size: 14px;" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="150.0" />
    </children>
</AnchorPane>
